# Optional — same-origin API base only (e.g. http://localhost:3000/api/v1 or https://app.example.com/api/v1).
# Do NOT set this to the backend origin; the browser must call /api/v1 on this Next app (proxy).
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Optional: static Bearer sent on login only (if your server requires it)
# NEXT_PUBLIC_API_LOGIN_BEARER=YOUR_SECRET_TOKEN

# Server-only — verify JWT in middleware when set (optional)
# JWT_SECRET=

# Backend origin for the Next.js proxy (server-side). Path /api/v1 is appended if missing.
BACKEND_API_URL=http://localhost:8080

# Optional — absolute base for serverFetch() / RSC (defaults to http://127.0.0.1:$PORT/api/v1)
# INTERNAL_API_URL=http://127.0.0.1:3000
